{
  "name": "backendbillarenlinea",
  "version": "1.0.0",
  "description": "este es backend de mi emprendimiento de billar en linea",
  "license": "ISC",
  "author": "Jeison Vargas",
  "type": "module",
  "main": "dist/main.js",
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "start": "node dist/main.js",
    "dev": "nodemon --watch src --ext ts --exec \"node --no-warnings=ExperimentalWarning --loader ts-node/esm src/main.ts\"",
    "build": "tsc -p tsconfig.json",
    "cloudinary": "^2.7.0",
    "db:clear": "node scripts/clear-database.mjs",
    "test": "node --test --no-warnings=ExperimentalWarning --loader ts-node/esm tests/app.test.ts",
    "seed": "npx tsx src/utils/seedData.ts",
    "seed:watch": "nodemon --watch src/utils/seedData.ts --ext ts --exec \"npx tsx src/utils/seedData.ts\"",
    "verify": "npx tsx src/utils/verifyData.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "multer": "^2.1.1",
    "@nestjs/platform-express": "^11.1.19",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.1",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-mongo-sanitize": "^1.3.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.2.3",
    "@types/nodemailer": "^7.0.11",
    "@types/supertest": "^7.2.0",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
